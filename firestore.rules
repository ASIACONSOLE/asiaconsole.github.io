rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Site verileri (logo, ayarlar, makaleler vb.)
    // Herkes okuyabilir, senkronizasyon için herkes yazabilir (geçici çözüm)
    match /site_data/{document=**} {
      allow read, write: if true;
    }

    // Daha güvenli bir yapı için ileride 'write' iznini 
    // sadece admin veya giriş yapmış kullanıcılarla sınırlandırmanızı öneririz.
    // Örnek: allow write: if request.auth != null;
  }
}
