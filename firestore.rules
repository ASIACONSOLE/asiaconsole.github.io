rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======================================================
    //  AsiaConsole - Firestore Güvenlik Kuralları
    // ======================================================
    // 
    // Bu kurallar tüm cihazlar arasında gerçek zamanlı 
    // senkronizasyonu (makaleler, ayarlar, bot konfigürasyonu vb.)
    // mümkün kılar.
    //
    // ======================================================

    match /site_data/{document=**} {
      // Okuma herkes için açık (SEO ve ziyaretçiler için)
      allow read: if true;
      
      // Yazma izni (Senkronizasyon için açık)
      // NOT: Daha yüksek güvenlik için Firebase Auth entegre edilip
      // 'allow write: if request.auth != null;' şeklinde güncellenmelidir.
      allow write: if true;
    }

    // Gelecekte eklenebilecek özel koleksiyonlar için koruma
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
