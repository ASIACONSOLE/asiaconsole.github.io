rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======================================================
    //  AsiaConsole - Firestore Güvenlik Kuralları
    // ======================================================
    // 
    // Okuma herkese açık (SEO ve ziyaretçiler için).
    // Yazma sadece belirli koşullarda izinlidir.
    //
    // ======================================================

    match /site_data/{document=**} {
      // Okuma herkes için açık (SEO ve ziyaretçiler için)
      allow read: if true;
      
      // SECURITY: Yazma izni — sadece boyut limiti ve temel doğrulama ile
      // Firestore Auth entegrasyonu yapıldığında:
      // allow write: if request.auth != null;
      // Şimdilik: İstek boyutu sınırlandırması ile temel koruma
      allow write: if request.resource.data.keys().size() < 50
                   && request.resource.size() < 1048576;
    }

    // Diğer tüm koleksiyonlar tamamen kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
